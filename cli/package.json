{
  "name": "specpact",
  "version": "1.0.1",
  "description": "Spec-Driven Development workflow tool — init, create, list, verify, and upgrade specs from the command line.",
  "bin": {
    "specpact": "bin/specpact.js"
  },
  "files": [
    "bin/",
    "src/",
    "templates/"
  ],
  "scripts": {
    "sync-templates": "node templates/sync-templates.js",
    "prepublishOnly": "node templates/sync-templates.js",
    "lint": "eslint src/ bin/",
    "test": "node --test tests/smoke.test.js"
  },
  "keywords": [
    "spec",
    "sdd",
    "spec-driven-development",
    "specpact",
    "cli"
  ],
  "author": "Obidjon Eshmamatov",
  "license": "MIT",
  "homepage": "https://github.com/specpact/specpact#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/specpact/specpact.git"
  },
  "bugs": {
    "url": "https://github.com/specpact/specpact/issues"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "inquirer": "^9.3.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "module"
}
